@using System.Security.Claims
@using XUnitBlog.App.Extensions
@using XUnitBlog.Domain.Entities
<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Blog</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/XUnitBlog.App.styles.css" asp-append-version="true" />


    @await RenderSectionAsync("Styles", required: false)

    <!-- UIkit CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/uikit@3.24.2/dist/css/uikit.min.css" />

    <!-- AlpineJS -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>

<body>
    <div class="uk-flex uk-height-viewport">
        <aside class="uk-width-medium uk-background-muted uk-flex uk-flex-column">
            <div class="uk-padding uk-padding-remove-bottom">
                <a href="/" class="uk-button uk-button-default uk-width-1-1">
                    <span uk-icon="reply"></span> Voltar ao Blog
                </a>
            </div>

            <hr class="uk-margin-remove">

            <nav class="uk-flex-1">
                <ul class="uk-nav uk-nav-default" uk-nav>
                    @if (User.RoleIsAdmin())
                    {
                        <li class="uk-parent">
                            <a asp-page="/Admin/Users">
                                <span uk-icon="user"></span> Usuários
                            </a>
                            <ul class="uk-nav-sub">
                                <li><a asp-page="/Admin/Users/Index">Todos</a></li>
                                <li><a asp-page="/Admin/Users/New">Novo</a></li>
                            </ul>
                        </li>
                    }
                    <li class="uk-parent">
                        <a asp-page="/Admin/Posts">
                            <span uk-icon="file-edit"></span> Posts
                        </a>
                        <ul class="uk-nav-sub">
                            <li><a asp-page="/Admin/Posts/Index">Todos</a></li>
                            <li><a asp-page="/Admin/Posts/New">Novo</a></li>
                        </ul>
                    </li>
                </ul>
            </nav>

            <div class="uk-padding-small uk-background-default">
                <div class="uk-flex uk-flex-middle" uk-grid>
                    <div class="uk-width-expand">
                        <span class="uk-text-small uk-text-muted">@User.Identity?.Name</span>
                    </div>
                    <div>
                        <form asp-page="/Auth/Logout" asp-route-returnUrl="/" method="post">
                            <button type="submit" class="uk-button uk-button-danger uk-button-small"
                                    uk-icon="sign-out">Sair</button>
                        </form>
                    </div>
                </div>
            </div>
        </aside>

        <main class="uk-flex-1 uk-background-white">
            <div class="uk-padding-large">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- UIkit JS -->
    <script src="https://cdn.jsdelivr.net/npm/uikit@3.24.2/dist/js/uikit.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/uikit@3.24.2/dist/js/uikit-icons.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>

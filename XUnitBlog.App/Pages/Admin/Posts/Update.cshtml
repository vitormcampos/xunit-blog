@page
@using XUnitBlog.App.Extensions
@using XUnitBlog.Domain.Entities
@model XUnitBlog.App.Pages.Admin.Posts.UpdateModel
@{
    ViewData["Title"] = "Editar Post";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet">
}

<div class="uk-container uk-flex uk-flex-center uk-margin-top">
    <form method="post" enctype="multipart/form-data" id="postForm">
        @foreach (var error in Model.Errors)
        {
            <div class="uk-alert-danger" uk-alert>
                <a href class="uk-alert-close" uk-close></a>
                <p><b>@error.Value</b></p>
            </div>
        }
        <input type="hidden" asp-for="UpdatePostDto.Content" id="Content" />
        <input type="hidden" asp-for="UpdatePostDto.Thumbnail" />
        <fieldset class="uk-fieldset">
            <legend class="uk-legend uk-margin">@ViewData["Title"]</legend>
            <div class="uk-child-width-1-1" uk-grid>
                <div>
                    <label asp-for="UpdatePostDto.Title">Titulo</label>
                    <input class="uk-input" type="text" asp-for="UpdatePostDto.Title" />
                </div>
                <div>
                    <label>Conteúdo</label>
                    <div id="editor" style="height: 300px;"></div>
                </div>
            </div>

            <div class="uk-child-width-1-2 uk-flex-middle" uk-grid>
                <div>
                    <label asp-for="UpdatePostDto.PostStatus">Status</label>
                    <select class="uk-input" type="text" asp-for="UpdatePostDto.PostStatus">
                        <option value="@PostStatuses.Draft">Rascunho</option>
                        <option value="@PostStatuses.Hidden">Oculto</option>
                        <option value="@PostStatuses.Published">Publicado</option>
                    </select>
                </div>
                <div>
                    <label>
                        <input class="uk-checkbox" type="checkbox" asp-for="UpdatePostDto.Pinned" /> Post fixado
                    </label>
                </div>
            </div>

            <div class="uk-margin" uk-margin>
                <div class="uk-width-1-1" uk-form-custom="target: true">
                    <input type="file" aria-label="Selecione a foto para thumbnail" asp-for="Thumbnail" />
                    <input class="uk-input uk-width-1-1" type="text" placeholder="Selecione a foto para thumbnail"
                           aria-label="Selecione a foto para thumbnail" disabled />
                </div>
            </div>
        </fieldset>

        <button class="uk-button uk-button-primary" type="submit">Salvar</button>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
    <script>
        var quill = new Quill('#editor', {
        theme: 'snow',
        placeholder: 'Escreva o conteúdo do post...',
        modules: {
        toolbar: [
        [{ 'header': [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
        ['link', 'image'],
        ['clean']
        ]
        }
        });

        document.addEventListener('DOMContentLoaded', function () {
        quill.root.innerHTML = '@Html.Raw(Model.UpdatePostDto.Content)';
        });

        document.getElementById('postForm').addEventListener('submit', function () {
        document.getElementById('Content').value = quill.root.innerHTML;
        });
    </script>
}
